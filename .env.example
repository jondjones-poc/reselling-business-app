# Copy to `.env` and fill in. Never commit `.env` (it is gitignored).

# Server
PORT=5003

# Postgres (see server.js — use a full connection string OR password-only path)
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
# SUPABASE_DB_URL=
# SUPABASE_DB_PASSWORD=

# Supabase — Project Settings → API → Project URL
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Secret API key (sb_secret_…) OR legacy service_role JWT (eyJ…).
# NOT the publishable / anon key (sb_publishable_… or wrong type).
# These two MUST be set on the Node API host (where server.js runs), including production —
# not only in the React build. Missing them yields "No public URL" for brand tag images.
SUPABASE_SERVICE_ROLE_KEY=

# Optional; must match Storage bucket id (default: brand-tag-images)
# SUPABASE_STORAGE_BRAND_TAGS_BUCKET=brand-tag-images

# Optional features
# GEMINI_API_KEY=

# eBay (Buy Browse API — application token, not your personal password)
# Create an app at https://developer.ebay.com/ → get OAuth credentials:
#   Client ID     → REACT_APP_EBAY_APP_ID  (or EBAY_APP)
#   Client Secret → REACT_APP_EBAY_CERT_ID
# Use the Production keyset. This grants marketplace search — it does NOT log in as your seller account.
# EBAY_APP=
# REACT_APP_EBAY_APP_ID=
# REACT_APP_EBAY_CERT_ID=
# Optional: Browse API category_ids (default 260012 = UK Men's Clothing)
# EBAY_BROWSE_CATEGORY_IDS=260012
#
# Seller Fulfillment (Authorization Code + refresh token in DB — preferred)
# User Tokens → create a RuName. Auth Accepted URL = http://localhost:{PORT}/api/ebay/oauth/callback
# EBAY_OAUTH_RU_NAME=Your_App_Name-PRD-xxxxxxxx-xxxxxxxx  (the RuName string — required; NOT the http URL)
# (Legacy: non-URL value only) If you mistakenly used EBAY_OAUTH_REDIRECT_URI for the RuName, that still works.
# Optional; where the browser lands after linking (defaults include /orders?tab=sales)
# EBAY_OAUTH_SUCCESS_REDIRECT_URL=http://localhost:3000/orders?tab=sales&ebay_oauth=success
# EBAY_OAUTH_ERROR_REDIRECT_URL=http://localhost:3000/orders?tab=sales&ebay_oauth=error
# Scopes (space-separated). Fulfillment read needs sell.fulfillment.readonly or sell.fulfillment
# EBAY_OAUTH_SCOPES=https://api.ebay.com/oauth/api_scope/sell.fulfillment.readonly
# Multiple integrations: one row per key in ebay_oauth_token
# EBAY_OAUTH_INTEGRATION_KEY=default
#
# Optional: HMAC key for OAuth `state` (default: derived from client id+secret). Set on Render if you rotate secrets.
# EBAY_OAUTH_STATE_SECRET=
#
# Override only for local debugging — production should use DB-stored refresh token
# EBAY_USER_ACCESS_TOKEN=
