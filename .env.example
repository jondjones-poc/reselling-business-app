# Copy to `.env` and fill in. Never commit `.env` (it is gitignored).

# Server
PORT=5003

# Frontend (Netlify): leave REACT_APP_API_BASE unset — public/_redirects proxies /api/* to Render.
# Setting REACT_APP_API_BASE to Render breaks auth cookies (401 on all routes after sign-in).
# REACT_APP_API_BASE=https://your-api.onrender.com

# Postgres (see server.js — use a full connection string OR password + SUPABASE_URL)
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
# SUPABASE_DB_URL=
# SUPABASE_DB_PASSWORD=
# Optional override when SUPABASE_URL is set (default: db.<project-ref>.supabase.co)
# SUPABASE_DB_HOST=
# Force IPv4 DNS only if your host lacks IPv6 (default: allow IPv6 — required for some Supabase regions)
# SUPABASE_DB_FORCE_IPV4=1

# Optional: require this value for GET /api/db-keepalive (Bearer token or ?secret=) — cron only, not the browser.
# Browser wake-up uses public GET /api/db-ping. Set on Render; same value as Cloudflare Worker secret.
# DB_KEEPALIVE_SECRET=

# Supabase — Project Settings → API → Project URL
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Google sign-in (server-side via Supabase — Google client ID/secret go in Supabase Dashboard only)
# Production frontend origin(s) for auth cookies/CORS (comma-separated) — required on Render
# AUTH_ALLOWED_ORIGINS=https://your-app.netlify.app
# Local dev only (omit on Render; localhost is added automatically in development)
FRONTEND_DEV_ORIGIN=http://localhost:3000
# Admin emails: always allowed to sign in + manage Settings → Access (comma-separated)
# AUTH_ADMIN_EMAILS=you@gmail.com
# Optional extra allowlist in env (also manageable in Settings → Access when admin)
# ALLOWED_AUTH_EMAILS=
# Database allowlist supports roles: admin | user (see database/auth_allowed_email.sql)
# All /api/* routes require a signed-in allowlisted session except db-ping, db-keepalive, and eBay OAuth callback.
# Session cookie lifetime in days (default 365). Supabase refresh token must still be valid.
# AUTH_SESSION_MAX_AGE_DAYS=365

# Secret API key (sb_secret_…) OR legacy service_role JWT (eyJ…).
# NOT the publishable / anon key (sb_publishable_… or wrong type).
# These two MUST be set on the Node API host (where server.js runs), including production —
# not only in the React build. Missing them yields "No public URL" for brand tag images.
SUPABASE_SERVICE_ROLE_KEY=

# Optional; must match Storage bucket id (default: brand-tag-images)
# SUPABASE_STORAGE_BRAND_TAGS_BUCKET=brand-tag-images

# Optional features
# GEMINI_API_KEY=

# eBay (Buy Browse API — application token, not your personal password)
# Create an app at https://developer.ebay.com/ → get OAuth credentials:
#   Client ID     → REACT_APP_EBAY_APP_ID  (or EBAY_APP)
#   Client Secret → REACT_APP_EBAY_CERT_ID
# Use the Production keyset. This grants marketplace search — it does NOT log in as your seller account.
# EBAY_APP=
# REACT_APP_EBAY_APP_ID=
# REACT_APP_EBAY_CERT_ID=
# Optional: Browse API category_ids (default 260012 = UK Men's Clothing)
# EBAY_BROWSE_CATEGORY_IDS=260012
#
# Seller Fulfillment (Authorization Code + refresh token in DB — preferred)
# User Tokens → create a RuName. Auth Accepted URL = http://localhost:{PORT}/api/ebay/oauth/callback
# EBAY_OAUTH_RU_NAME=Your_App_Name-PRD-xxxxxxxx-xxxxxxxx  (the RuName string — required; NOT the http URL)
# (Legacy: non-URL value only) If you mistakenly used EBAY_OAUTH_REDIRECT_URI for the RuName, that still works.
# Optional; where the browser lands after linking when no return_to was passed at connect time
# EBAY_OAUTH_SUCCESS_REDIRECT_URL=http://localhost:3000/orders?tab=sales&ebay_oauth=success
# EBAY_OAUTH_ERROR_REDIRECT_URL=http://localhost:3000/orders?tab=sales&ebay_oauth=error
# Extra origins allowed for return_to (comma-separated), e.g. your Netlify URL when RuName callback hits Render
# EBAY_OAUTH_ALLOWED_RETURN_ORIGINS=https://your-app.netlify.app
# Scopes (space-separated). Default is sell.fulfillment.readonly only (Orders / Fulfillment).
# Item Views needs Analytics: enable Sell Analytics API in the eBay Developer Portal, then set:
# EBAY_OAUTH_INCLUDE_ANALYTICS=1
# Or set all scopes explicitly:
# EBAY_OAUTH_SCOPES=https://api.ebay.com/oauth/api_scope/sell.fulfillment.readonly https://api.ebay.com/oauth/api_scope/sell.analytics.readonly
# Multiple integrations: one row per key in ebay_oauth_token
# EBAY_OAUTH_INTEGRATION_KEY=default
#
# Optional: HMAC key for OAuth `state` (default: derived from client id+secret). Set on Render if you rotate secrets.
# EBAY_OAUTH_STATE_SECRET=
#
# Override only for local debugging — production should use DB-stored refresh token
# EBAY_USER_ACCESS_TOKEN=
